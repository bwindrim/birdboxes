#!/bin/bash

FILE=$(date +"{{ image_prefix }}_%FT%H:%M:%S.jpg")
LOCAL_PATH=/mnt/local/photo

/usr/bin/rpicam-still --mode 1640:1232:10 --nopreview --tuning-file /usr/share/libcamera/ipa/rpi/vc4/imx219_noir.json --width 640 --height 480 --quality 75 -o - | tee $LOCAL_PATH/$FILE
chmod a-w $LOCAL_PATH/$FILE

