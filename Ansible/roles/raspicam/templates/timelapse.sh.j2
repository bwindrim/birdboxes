#!/bin/bash

FILE=$(date +"{{ image_prefix }}_%FT%H-%M-%S.jpg")
LOCAL_PATH=/mnt/local/timelapse
REMOTE_PATH=/mnt/remote/{{ inventory_hostname }}/timelapse

/usr/bin/libcamera-still --awbgains 0.9,0.5 --nopreview --timeout 5 --width 1024 --height 768 -q 75 --tuning-file /usr/share/libcamera/ipa/rpi/vc4/imx219_noir.json -o $LOCAL_PATH/$FILE
chmod a-w $LOCAL_PATH/$FILE

if [ -d "$REMOTE_PATH" ]; then
    cp -p $LOCAL_PATH/$FILE $REMOTE_PATH/$FILE
fi
